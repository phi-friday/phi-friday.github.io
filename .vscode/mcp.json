{
  "servers": {
    "context7": {
      "type": "http",
      "url": "https://mcp.context7.com/mcp"
    },
    "svelte": {
      "type": "stdio",
      "command": "bunx",
      "args": ["-y", "@sveltejs/mcp"]
    },
    "eslint": {
      "type": "stdio",
      "command": "bunx",
      "args": ["@eslint/mcp@latest"]
    },
    "oraios/serena": {
      "type": "stdio",
      "command": "uvx",
      "args": [
        "--from",
        "git+https://github.com/oraios/serena",
        "serena",
        "start-mcp-server",
        "--context",
        "ide",
        "--project",
        "${workspaceFolder}",
        "--open-web-dashboard",
        "false"
      ]
    }
  }
}
